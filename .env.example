# Firebase Configuration Template
# 
# Instructions:
# 1. Copy this file to .env
# 2. Replace the values with your Firebase credentials
# 3. Set these environment variables before running app.py
#
# Windows Command Prompt:
#   set GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json
#   set FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
#
# Windows PowerShell:
#   $env:GOOGLE_APPLICATION_CREDENTIALS = "C:\path\to\serviceAccountKey.json"
#   $env:FIREBASE_STORAGE_BUCKET = "your-project-id.appspot.com"
#
# Linux/Mac:
#   export GOOGLE_APPLICATION_CREDENTIALS="/path/to/serviceAccountKey.json"
#   export FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# Path to your Firebase service account JSON file
# Download this from: Firebase Console > Settings > Service Accounts > Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/serviceAccountKey.json

# Firebase Storage bucket name
# Find this at: Firebase Console > Storage > Bucket name (format: project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
